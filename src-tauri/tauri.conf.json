{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "WinMux",
  "version": "0.4.4",
  "identifier": "com.winmux.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && cargo build --release --bin winmux-daemon --manifest-path src-tauri/Cargo.toml"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WinMux",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "WinMux — double-click to open"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/HarjjotSinghh/winmux/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyNkY4QkM1NUY3RjgzNzgKUldSNGczOWZ4WXR2RW1ZV0xVOXlETTZzSGRZZUxtWmVCVjN0eVpnNHpBQThoTzFUdW1QMklXMXUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
